<body>
  <div class="shell">
    <header class="topbar">
      <span id="topDot" class="top-dot"></span>
      <div class="title">
        <h1 id="headline">Ringside mission control</h1>
        <div id="subtitle" class="subtitle">no ringers running</div>
      </div>
      <div id="clock" class="clock">00:00</div>
    </header>
    <main id="app"><div class="empty">no ringers running</div></main>
  </div>
  <script>
    const app = document.getElementById("app");
    const headline = document.getElementById("headline");
    const subtitle = document.getElementById("subtitle");
    const topDot = document.getElementById("topDot");
    const clock = document.getElementById("clock");
    let currentRuns = [];
    const runNodes = new Map();
    let emptyNode = app.querySelector(".empty");

    function setText(node, value) {
      const text = String(value ?? "");
      if (node.textContent !== text) node.textContent = text;
    }

    function setTitle(node, value) {
      const text = String(value ?? "");
      if (node.title !== text) node.title = text;
