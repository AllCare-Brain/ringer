    function createEmptyNode() {
      const node = document.createElement("div");
      node.className = "empty";
      node.textContent = "no ringers running";
      return node;
    }

    function runKey(run, index) {
      const direct = run.run_id ?? run.id;
      if (direct) return String(direct);
      const parts = [run.identity, run.run_name, run.started_at, run.pid, run.port]
        .filter(value => value !== undefined && value !== null && value !== "");
      return parts.length > 0 ? parts.map(String).join("|") : `run-${index}`;
    }

    function taskKey(task, index) {
      return String(task.__taskKey || task.key || task.id || task.name || `task-${index}`);
    }

    function taskTailText(task) {
      const tail = Array.isArray(task.log_tail)
        ? task.log_tail
        : (task.log_tail ? [task.log_tail] : []);
      return tail.map(line => String(line).trim()).filter(Boolean).join(" / ");
    }

    function createRunRecord(key) {
      const node = document.createElement("section");
      node.className = "run";
      node.setAttribute("data-run-id", key);

      const head = document.createElement("header");
      head.className = "run-head";

      const dot = document.createElement("span");
      dot.className = "dot";

      const main = document.createElement("div");
      main.className = "run-main";

      const name = document.createElement("div");
      name.className = "run-name";

      const identity = document.createElement("span");
      identity.className = "identity";

      const meta = document.createElement("div");
      meta.className = "run-meta";

      const elapsed = document.createElement("span");
      elapsed.className = "run-elapsed";

      const tokens = document.createElement("span");
      tokens.className = "run-tokens";

      const final = document.createElement("span");
      final.className = "final";

      const tasks = document.createElement("div");
      tasks.className = "tasks";

      main.append(name, identity);
      meta.append(elapsed, tokens, final);
      head.append(dot, main, meta);
      node.append(head, tasks);

      return {
        node,
        tasks: new Map(),
        elements: {dot, name, identity, elapsed, tokens, final, tasks}
      };
    }

    function createTaskRecord(key) {
      const node = document.createElement("div");
      node.className = "task";
      node.setAttribute("data-task-key", key);

      const name = document.createElement("div");
      name.className = "task-key";

      const status = document.createElement("div");
      status.className = "task-status";

      const elapsed = document.createElement("div");
      elapsed.className = "task-elapsed";

      const children = document.createElement("div");
      children.className = "children";

      const log = document.createElement("div");
      log.className = "task-log";
      log.hidden = true;

      node.append(name, status, elapsed, children, log);

      return {node, elements: {name, status, elapsed, children, log}};
    }

    function updateTaskRecord(record, task) {
      const status = task.status || "queued";
      const tail = taskTailText(task);
      const tokens = numberOrZero(task.tokens);
      const elapsed = tokens > 0
        ? `${fmtElapsed(task.elapsed_s)} / ${tokens.toLocaleString()} tok`
        : fmtElapsed(task.elapsed_s);
