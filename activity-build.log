    function syncRunNodes(runs) {
      if (runs.length === 0) {
        for (const [, record] of runNodes) record.node.remove();
        runNodes.clear();
        if (!emptyNode) emptyNode = createEmptyNode();
        if (app.firstElementChild !== emptyNode || app.childElementCount !== 1) {
          app.replaceChildren(emptyNode);
        }
        return;
      }

      if (emptyNode?.isConnected) emptyNode.remove();

      const seen = new Set();
      const orderedNodes = [];
      runs.forEach((run, index) => {
        const key = runKey(run, index);
        let record = runNodes.get(key);
        if (!record) {
          record = createRunRecord(key);
          runNodes.set(key, record);
        }
        seen.add(key);
        updateRunRecord(record, run);
        orderedNodes.push(record.node);
      });

      for (const [key, record] of runNodes) {
        if (!seen.has(key)) {
          record.node.remove();
          runNodes.delete(key);
        }
      }

      reconcileOrder(app, orderedNodes);
    }

    function updateTopbar(runs) {
      const liveRuns = runs.filter(run => run.state === "live");
      const anyFailure = runs.some(run => run.state === "died" || Number(run.fail || 0) > 0);
      const newest = runs[0];
      let dotClass = "";
      if (anyFailure) dotClass = "fail";
      else if (liveRuns.length > 0) dotClass = "live";
      else if (newest && newest.state === "finished" && Number(newest.pass || 0) > 0) dotClass = "pass";
      const topDotClass = `top-dot ${dotClass}`;
      if (topDot.className !== topDotClass) topDot.className = topDotClass;

      if (liveRuns.length > 1) {
        const agents = liveRuns.reduce((sum, run) => sum + (run.tasks || []).length, 0);
        setText(headline, `${liveRuns.length} ringers`);
        setText(subtitle, `${agents} agents`);
      } else if (liveRuns.length === 1) {
        setText(headline, liveRuns[0].run_name || "ringer");
        setText(subtitle, liveRuns[0].identity || "unknown");
      } else if (newest) {
        setText(headline, newest.state === "died" ? `${newest.run_name || "ringer"} died` : (newest.run_name || "ringer"));
        setText(subtitle, `${runs.length} ringer${runs.length === 1 ? "" : "s"}`);
      } else {
        setText(headline, "Ringside mission control");
        setText(subtitle, "no ringers running");
      }
      const maxElapsed = runs.reduce((max, run) => Math.max(max, Number(run.elapsed_s || 0)), 0);
      setText(clock, fmtElapsed(maxElapsed));
    }

    function update(payload) {
      currentRuns = normalizePayload(payload);
      updateTopbar(currentRuns);
      syncRunNodes(currentRuns);
    }

    async function pollLocalState() {
      try {
        const response = await fetch(`/state.json?t=${Date.now()}`, {cache: "no-store"});
        if (!response.ok) return;
        const state = await response.json();
        update(Array.isArray(state) ? state : [state]);
      } catch (_err) {
      }
    }

    setInterval(() => update(currentRuns), 250);
    setInterval(pollLocalState, 1000);
    pollLocalState();

    (function loadTauriHudBridge() {
      if (!window.__TAURI__) return;
      const script = document.createElement("script");
      script.src = "hud.js";
      script.defer = true;
      document.head.appendChild(script);
    })();
