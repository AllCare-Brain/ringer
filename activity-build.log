+    for line in lines:
+        if looks_like_assistant_text(line):
+            return shorten(clean_log_text(line), ACTIVITY_TEXT_LIMIT)
+    return ""
+
+
+def activity_fallback(log_tail: list[str]) -> str:
+    for line in reversed(log_tail):
