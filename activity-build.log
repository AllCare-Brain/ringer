+    return bool(re.match(r"^(?:[A-Za-z0-9_./-]+)(?:\.[A-Za-z0-9_+-]+)?$", first))
+
+
+def extract_written_file(line: str) -> str:
+    if line.startswith("[ringer.py]"):
