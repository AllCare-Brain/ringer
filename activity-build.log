+def last_assistant_activity(text: str) -> str:
+    lines = list(reversed(non_empty_log_lines(text)))
+    for line in lines:
+        match = ASSISTANT_PREFIX_RE.match(line)
+        if match:
+            candidate = clean_log_text(match.group("text"))
+            if candidate:
